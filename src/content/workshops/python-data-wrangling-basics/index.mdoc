pythonCells:
  - label: Load and inspect data
    code: |
      import pandas as pd

      df = pd.read_csv("students.csv")
      print(df.head())
      print(df.info())
  - label: Grouped summary by major
    code: |
      summary = (
          df.groupby("major", as_index=False)
            .agg(avg_gpa=("gpa", "mean"), count=("student_id", "count"))
            .sort_values("avg_gpa", ascending=False)
      )
      print(summary)
